# Docker Compose 镜像覆盖（复制为 deploy/.env 或 export 后执行 zest-stack-up）
# 国内 ghcr 不通时示例:
# LITELLM_IMAGE=docker.m.daocloud.io/ghcr.io/berriai/litellm:main-latest
# WIREMOCK_IMAGE=docker.m.daocloud.io/wiremock/wiremock:3.3.1
# MYSQL_IMAGE=mysql:8.0

LITELLM_IMAGE=ghcr.io/berriai/litellm:main-latest
WIREMOCK_IMAGE=wiremock/wiremock:3.3.1
MYSQL_IMAGE=mysql:8.0

# --- B 整合栈（large + integration profile）---
# bash deploy/scripts/zest-stack-up.sh large
# ZEST_LLM_ADAPTERS_AGENT_RUNTIME=dify
# ZEST_LLM_ADAPTERS_KNOWLEDGE_RETRIEVAL=ragflow
# ZEST_LLM_ADAPTERS_LEARNING_PIPELINE=zest-eval
# DIFY_API_BASE=http://dify-api:5001
# RAGFLOW_API_BASE=http://ragflow:9380
# DIFY_SECRET_KEY=change-me-in-production
# RAGFLOW_API_KEY=
# Demo: bash deploy/scripts/integration-demo.sh
# 严格验收: ZEST_INTEGRATION_E2E=1 bash deploy/scripts/e2e-acceptance.sh
